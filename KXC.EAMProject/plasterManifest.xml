              help="Scaffold targeting the PreProd environment."
              value="PreProd" />
      <choice label="&amp;Prod"
              help="Scaffold targeting the Production environment."
              value="Prod" />
    </parameter>

    <!-- Change Reference -->
    <parameter name="ChangeReference"
               type="text"
               prompt="Change reference number (e.g. CHG0012345)"
               default="CHG0000000" />

  </parameters>


# Auto-detect text files and normalise line endings to LF on check-in
* text=auto eol=lf

# PowerShell
*.ps1    text eol=lf
*.psm1   text eol=lf
*.psd1   text eol=lf
*.ps1xml text eol=lf

# Markup / Config
*.md     text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.xml    text eol=lf
*.csv    text eol=lf

# Binary — do not modify
*.png    binary
*.jpg    binary
*.zip    binary
*.dll    binary
